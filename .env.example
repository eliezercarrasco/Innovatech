# Innovatech — Variables de entorno
# Copiar a .env y completar con valores reales
# El archivo .env está en .gitignore y NO se sube al repositorio

# ─── MySQL - Base de datos Despachos ───────────────────────────────────────
MYSQL_DESPACHOS_ROOT_PASSWORD=rootpassword
MYSQL_DESPACHOS_DATABASE=despachos_db
MYSQL_DESPACHOS_USER=despachos_user
MYSQL_DESPACHOS_PASSWORD=despachos_pass

# ─── MySQL - Base de datos Ventas ──────────────────────────────────────────
MYSQL_VENTAS_ROOT_PASSWORD=rootpassword
MYSQL_VENTAS_DATABASE=ventas_db
MYSQL_VENTAS_USER=ventas_user
MYSQL_VENTAS_PASSWORD=ventas_pass

# ─── Backend Despachos ─────────────────────────────────────────────────────
DB_DESPACHOS_ENDPOINT=db-despachos
DB_DESPACHOS_PORT=3306

# ─── Backend Ventas ────────────────────────────────────────────────────────
DB_VENTAS_ENDPOINT=db-ventas
DB_VENTAS_PORT=3306

# ─── Frontend / Nginx ──────────────────────────────────────────────────────
BACKEND_DESPACHOS_HOST=backend-despachos
BACKEND_VENTAS_HOST=backend-ventas

# ─── Docker Hub (solo para CI/CD — NO poner aquí tokens reales) ────────────
# Configurar como GitHub Secrets:
# DOCKERHUB_USERNAME=eliezercarrasco
# DOCKERHUB_TOKEN=<token>

# ─── AWS EC2 (solo para CI/CD — NO poner aquí datos reales) ───────────────
# Configurar como GitHub Secrets:
# EC2_FRONTEND_HOST=<ip-publica>
# EC2_BACKEND_HOST=<ip-publica>
# EC2_USERNAME=ubuntu
# EC2_SSH_KEY=<contenido-del-pem>
